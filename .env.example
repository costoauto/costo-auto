PORT=3000
# In locale puoi continuare a usare un solo URL:
DATABASE_URL=postgresql://auto_tco_web:PASSWORD@HOST:5432/DATABASE_NAME
DATABASE_SSL=false

# Su Render useremo invece questi campi separati, evitando di inserire la
# password dentro un URL:
# DATABASE_HOST=aws-0-eu-west-1.pooler.supabase.com
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_USER=auto_tco_web.PROJECT_REF
# DATABASE_PASSWORD=PASSWORD_RISERVATA_DEL_SITO
